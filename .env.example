# ==============================================================================
# Chairly AppHost — Required Configuration
# ==============================================================================
#
# Copy this file to .env and fill in the secret values:
#   cp .env.example .env
#
# Then run the setup script to load values into dotnet user-secrets:
#   bash scripts/setup-user-secrets.sh
#
# WARNING: Do NOT reuse these values in production environments.
# Production deployments must use unique, strong credentials managed via a
# proper secrets management solution (e.g. Azure Key Vault, AWS Secrets Manager).
#
# This file is NOT loaded by the application. It serves as documentation only.
# ==============================================================================

# Aspire parameters
Parameters__rabbitmq-user=chairly
Parameters__rabbitmq-password=<your-rabbitmq-password>
Parameters__keycloak-admin-password=<your-keycloak-admin-password>
Parameters__keycloak-admin-client-secret=<your-keycloak-client-secret>

# Application config
Chairly__DefaultRealm=chairly
Chairly__DefaultTenantId=00000000-0000-0000-0000-000000000001

# SMTP
Smtp__FromAddress=noreply@chairly.local
Smtp__FromName=Chairly

# Keycloak
Keycloak__ClientId=chairly-frontend
Keycloak__AdminClientId=chairly-admin
Keycloak__AdminPortalRealm=chairly-admin
Keycloak__AdminPortalClientId=chairly-admin-portal
Keycloak__SmtpHost=maildev
Keycloak__SmtpPort=1025
